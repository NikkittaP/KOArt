# Copy to .env and fill in. .env is gitignored and never committed.

YII_DEBUG=true
YII_ENV=dev

# OSPanel 6: DB host is the module name (e.g. MySQL-8.0), NOT localhost.
# Production: host=localhost, real DB user/password.
DB_DSN=mysql:host=MySQL-8.0;dbname=oskina_art
DB_USERNAME=root
DB_PASSWORD=

# Generate a key with: php -r "echo bin2hex(random_bytes(16));"
COOKIE_VALIDATION_KEY=
