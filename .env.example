# Copy to .env and fill in. .env is gitignored and never committed.

YII_DEBUG=true
YII_ENV=dev

# OSPanel 6: DB host is the module name (e.g. MySQL-8.0), NOT localhost.
# Production: host=localhost, real DB user/password.
DB_DSN=mysql:host=MySQL-8.0;dbname=oskina_art
DB_USERNAME=root
DB_PASSWORD=

# Generate a key with: php -r "echo bin2hex(random_bytes(16));"
COOKIE_VALIDATION_KEY=

# Mail (contact form). Local/dev: keep MAIL_USE_FILE_TRANSPORT=true — nothing is
# sent, mails are written to runtime/mail.
# Production (Gmail): set MAIL_USE_FILE_TRANSPORT=false and use a Gmail
# App Password (needs 2-Step Verification enabled) as MAIL_PASSWORD.
MAIL_USE_FILE_TRANSPORT=true
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_ENCRYPTION=tls
MAIL_USERNAME=ekaterina.oskina@gmail.com
MAIL_PASSWORD=
